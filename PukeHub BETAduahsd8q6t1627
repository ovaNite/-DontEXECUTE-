local function AddToggle(name, prop, parent, order)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1, -10, 0, 45)
    btn.BackgroundColor3 = Color3.fromRGB(25,35,25)
    btn.TextColor3 = Color3.new(1,1,1)
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Font = Enum.Font.GothamBold
    btn.Text = "  "..name
    btn.LayoutOrder = order
    Janitor:AddInst(Instance.new("UICorner", btn))
    btn.MouseButton1Click:Connect(function()
        Settings[prop] = not Settings[prop]
        btn.BackgroundColor3 = Settings[prop] and Color3.fromRGB(0,200,100) or Color3.fromRGB(25,35,25)
    end)
    if Settings[prop] then btn.BackgroundColor3 = Color3.fromRGB(0,200,100) end
    return btn
end

local function AddSlider(name, min, max, prop, parent, order)
    local frame = Instance.new("Frame", parent)
    frame.Size = UDim2.new(1, -10, 0, 55)
    frame.BackgroundTransparency = 1
    frame.LayoutOrder = order
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1, 0, 0, 20)
    label.TextColor3 = Color3.new(1,1,1)
    label.Font = Enum.Font.Gotham
    label.BackgroundTransparency = 1
    label.Text = name..": "..Settings[prop]
    local bg = Instance.new("Frame", frame)
    bg.Size = UDim2.new(1,-10,0,4)
    bg.Position = UDim2.new(0,5,0,35)
    bg.BackgroundColor3 = Color3.new(0.1,0.2,0.1)
    local fill = Instance.new("Frame",bg)
    fill.Size = UDim2.new((Settings[prop]-min)/(max-min),0,1,0)
    fill.BackgroundColor3 = Color3.fromRGB(0,255,120)
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local move
            move = RunService.RenderStepped:Connect(function()
                local p = math.clamp((GetCorrectedMousePos().X - bg.AbsolutePosition.X)/bg.AbsoluteSize.X, 0, 1)
                Settings[prop] = math.round(min + (p*(max-min)))
                label.Text = name..": "..Settings[prop]
                fill.Size = UDim2.new(p, 0, 1, 0)
            end)
            UIS.InputEnded:Connect(function(e)
                if e.UserInputType == Enum.UserInputType.MouseButton1 then move:Disconnect() end
            end)
        end
    end)
    return frame
end

