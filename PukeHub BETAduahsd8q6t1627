local function RefreshPlayerButtons()
    for _, child in pairs(PlayersFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LP then
            local btn = Instance.new("TextButton", PlayersFrame)
            btn.Size = UDim2.new(1, 0, 0, 30)
            btn.Text = "  " .. player.Name
            btn.Font = Enum.Font.GothamBold
            btn.TextColor3 = Color3.new(1,1,1)
            btn.BackgroundColor3 = Color3.fromRGB(25, 35, 25)
            Janitor:AddInst(Instance.new("UICorner", btn))
            local function updateColor()
                btn.BackgroundColor3 = SelectedPlayers[player] and Color3.fromRGB(0,200,100) or Color3.fromRGB(25,35,25)
            end
            updateColor()
            btn.MouseButton1Click:Connect(function()
                SelectedPlayers[player] = not SelectedPlayers[player]
                updateColor()
            end)
        end
    end
end

