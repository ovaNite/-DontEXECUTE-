local function GetCorrectedMousePos()
    return UIS:GetMouseLocation()
end

local function IsAlive(player)
    return player and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0
end

local function IsOnMyTeam(player)
    if not Settings.TeamCheck then return false end
    if not LP.Team or not player.Team then return false end
    return player.Team == LP.Team or player.TeamColor == LP.TeamColor
end

local function GetBestTarget()
    local target, shortest = nil, Settings.AimRadius
    local mouseLoc = GetCorrectedMousePos()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LP and IsAlive(player) and not IsOnMyTeam(player) then
            local aimPartInstance = player.Character and player.Character:FindFirstChild(Settings.AimPart)
            if aimPartInstance then
                local dist = (LP.Character.HumanoidRootPart.Position - aimPartInstance.Position).Magnitude
                if dist <= Settings.MaxDist then
                    local pos, vis = Camera:WorldToViewportPoint(aimPartInstance.Position)
                    if vis then
                        local mDist = (Vector2.new(pos.X, pos.Y) - mouseLoc).Magnitude
                        if mDist < shortest then
                            target = player
                            shortest = mDist
                        end
                    end
                end
            end
        end
    end
    return target
end

local function PredictPosition(target)
    local char = target.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    local part = char:FindFirstChild(Settings.AimPart) or root
    if not root or not part then return nil end
    local velocity = root.Velocity
    local predictionTime = Settings.PredictionStrength / 50
    return part.Position + velocity * predictionTime
end

