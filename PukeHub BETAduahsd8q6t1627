Janitor:Add(RunService.RenderStepped:Connect(function()
    local mouseLoc = GetCorrectedMousePos()
    FOVCircle.Visible = Settings.ShowFOV
    FOVCircle.Radius = Settings.AimRadius
    FOVCircle.Position = mouseLoc

    if Settings.Aimbot and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        if not AICore.LockedTarget or not IsAlive(AICore.LockedTarget) or IsOnMyTeam(AICore.LockedTarget) then
            AICore.LockedTarget = GetBestTarget()
        end
        if AICore.LockedTarget and IsAlive(AICore.LockedTarget) then
            local aimPartInstance = AICore.LockedTarget.Character and AICore.LockedTarget.Character:FindFirstChild(Settings.AimPart)
            if aimPartInstance then
                local targetPos = PredictPosition(AICore.LockedTarget)
                if targetPos then
                    local pos, vis = Camera:WorldToViewportPoint(targetPos)
                    if vis then
                        local distToMouse = (Vector2.new(pos.X, pos.Y) - mouseLoc).Magnitude
                        if distToMouse <= Settings.AimRadius + 100 then
                            mousemoverel((pos.X - mouseLoc.X) / Settings.AimPower, (pos.Y - mouseLoc.Y) / Settings.AimPower)
                        else AICore.LockedTarget = nil end
                    else AICore.LockedTarget = nil end
                else AICore.LockedTarget = nil end
            else AICore.LockedTarget = nil end
        else AICore.LockedTarget = nil end
    else AICore.LockedTarget = nil end

        if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") and Settings.WalkSpeed > 0 then
        if LP.Character.Humanoid.MoveDirection.Magnitude > 0 then
            LP.Character.HumanoidRootPart.CFrame = LP.Character.HumanoidRootPart.CFrame + (LP.Character.Humanoid.MoveDirection * (Settings.WalkSpeed / 5))
        end
    end

    if Settings.ESP then
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LP and v.Character then
                local hl = v.Character:FindFirstChild("GreenMatrixHL")
                if IsAlive(v) and not IsOnMyTeam(v) then
                    if not hl then
                        hl = Instance.new("Highlight", v.Character)
                        hl.Name = "GreenMatrixHL"
                        hl.FillTransparency = 0.5
                        hl.FillColor = Settings.ESP_Color
                    end
                    hl.Enabled = true
                else
                    if hl then hl.Enabled = false end
                end
            end
        end
    end
end))

