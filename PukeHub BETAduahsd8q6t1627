local function ClearPlayerAssets(player)
    pcall(function()
        if player.Character then
            local hl = player.Character:FindFirstChild("GreenMatrixHL")
            if hl then hl:Destroy() end
        end
        if AICore.LockedTarget == player then AICore.LockedTarget = nil end
    end)
end

