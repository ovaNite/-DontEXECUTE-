local function AttachToHumanoidRoot(targetChar, playerChar)
    if not targetChar or not targetChar:FindFirstChild("HumanoidRootPart") then return end
    if not playerChar or not playerChar:FindFirstChild("HumanoidRootPart") then return end
    local existingWeld = playerChar.HumanoidRootPart:FindFirstChild("GreenHubBringWeld")
    if existingWeld then existingWeld:Destroy() end
    local weld = Instance.new("WeldConstraint")
    weld.Name = "GreenHubBringWeld"
    weld.Part0 = playerChar.HumanoidRootPart
    weld.Part1 = targetChar.HumanoidRootPart
    weld.Parent = playerChar.HumanoidRootPart
end

BringButton.MouseButton1Click:Connect(function()
    if not LP.Character or not LP.Character:FindFirstChild("HumanoidRootPart") then return end
    local yourRoot = LP.Character.HumanoidRootPart
    for player, selected in pairs(SelectedPlayers) do
        if selected and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            player.Character.HumanoidRootPart.CFrame = yourRoot.CFrame * CFrame.new(0, 0, -5)
            AttachToHumanoidRoot(LP.Character, player.Character)
        end
    end
end)

